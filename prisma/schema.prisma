generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String   @default("")
  coverImage    String?
  category      String   @default("AI Tools")
  tags          String   @default("[]")
  seoTitle      String?
  seoDesc       String?
  featured      Boolean  @default(false)
  trending      Boolean  @default(false)
  published     Boolean  @default(false)
  autoGenerated Boolean  @default(false)
  sourceUrl     String?
  viewCount     Int      @default(0)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  affiliateLinks AffiliateLink[]
}

model AffiliateLink {
  id              String   @id @default(cuid())
  blogPostId      String
  toolName        String
  affiliateUrl    String
  commissionRate  String?
  commissionType  String?  @default("recurring")
  description     String?
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  blogPost BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
}

model TrendingTopic {
  id          String   @id @default(cuid())
  keyword     String
  searchVol   String?
  difficulty  String?
  trendScore  Float    @default(0)
  source      String   @default("web_search")
  category    String   @default("AI Tools")
  researched  Boolean  @default(false)
  usedForPost Boolean  @default(false)
  rawData     String?
  createdAt   DateTime @default(now())
}

model AutoPostConfig {
  id                String   @id @default(cuid())
  postsPerDay       Int      @default(2)
  autoPublish       Boolean  @default(false)
  lastRunAt         DateTime?
  isActive          Boolean  @default(true)
  categories        String   @default("AI Tools,SaaS,Productivity,Marketing,Developer")
  affiliatePrograms String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
