# ===========================================
# AI Toolkit Hub - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in Project Settings > Environment Variables

# ── DATABASE (Required) ──────────────────
# PostgreSQL connection string (use Vercel Postgres, Supabase, Neon, etc.)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ── AI / OpenRouter (Required) ───────────
# Get your API key at https://openrouter.ai/keys
# Uses auto model selection by default (picks best model for the task)
OPENROUTER_API_KEY=

# Optional: Override the auto model selection with a specific model
# Examples: "google/gemini-2.0-flash-001", "anthropic/claude-3.5-sonnet", "openai/gpt-4o"
# Default: "openrouter/auto" (auto-selects the best model)
OPENROUTER_MODEL=

# ── WEB SEARCH (Optional) ────────────────
# SerpAPI key for real web search (trending topic research)
# Without this, AI-generated research is used as fallback
# Get yours at https://serpapi.com/
SERPAPI_KEY=

# ── EMAIL NOTIFICATIONS (Optional) ───────
# Resend API key for sending email notifications when someone subscribes
# Get yours at https://resend.com/
# Without this, notifications are logged to console only
RESEND_API_KEY=

# Owner email for subscriber notifications
OWNER_EMAIL=koechbrian245@gmail.com

# ── IMAGE GENERATION (Optional) ──────────
# If you have an image generation API (e.g., DALL-E via OpenRouter)
IMAGE_API_KEY=
IMAGE_API_URL=

# ── SITE CONFIG ──────────────────────────
# Your site URL (used for OpenRouter referer header and SEO)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
